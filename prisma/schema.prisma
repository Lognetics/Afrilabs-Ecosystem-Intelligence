// Production schema — Postgres.
// To deploy: copy this over schema.prisma:
//   cp prisma/schema.postgres.prisma prisma/schema.prisma
// Then set DATABASE_URL to your Postgres connection string and run:
//   npx prisma migrate deploy   (or `prisma db push` for first deploy)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Identity & RBAC ─────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String
  department   String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedPartnerships Partnership[]   @relation("PartnershipOwner")
  ownedPrograms     Program[]       @relation("ProgramLead")
  activities        Activity[]
  messages          Message[]
  taskAssignments   Task[]          @relation("TaskAssignee")
  campaignsCreated  Campaign[]      @relation("CampaignCreator")
}

model Department {
  id        String  @id @default(cuid())
  code      String  @unique
  name      String
  headEmail String?
  createdAt DateTime @default(now())
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  type        String
  website     String?
  email       String?
  phone       String?
  country     String?
  region      String?
  sector      String?
  description String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partnerships   Partnership[]
  contacts       PartnerContact[]
  fundingSources FundingSource[]
}

model PartnerContact {
  id        String  @id @default(cuid())
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  fullName  String
  title     String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
}

model Partnership {
  id          String   @id @default(cuid())
  partnerId   String
  partner     Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  ownerId     String?
  owner       User?    @relation("PartnershipOwner", fields: [ownerId], references: [id])
  title       String
  stage       String
  value       Float?
  currency    String   @default("USD")
  source      String?
  notes       String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  programLinks  PartnershipProgram[]
  fundingLinks  PartnershipFunding[]
  events        EventPartner[]
  activities    Activity[]
  messages      Message[]
}

model PartnershipProgram {
  id            String   @id @default(cuid())
  partnershipId String
  programId     String
  role          String?
  partnership   Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  program       Program     @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([partnershipId, programId])
}

model PartnershipFunding {
  id              String @id @default(cuid())
  partnershipId   String
  fundingSourceId String
  partnership     Partnership   @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  fundingSource   FundingSource @relation(fields: [fundingSourceId], references: [id], onDelete: Cascade)

  @@unique([partnershipId, fundingSourceId])
}

model Program {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  type        String
  status      String
  startDate   DateTime?
  endDate     DateTime?
  description String?
  region      String?
  budget      Float?
  leadId      String?
  lead        User?    @relation("ProgramLead", fields: [leadId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partners        PartnershipProgram[]
  fundingSources  FundingSource[]
  events          Event[]
  startups        ProgramStartup[]
  hubs            ProgramHub[]
  activities      Activity[]
  messages        Message[]
  metrics         ProgramMetric[]
}

model ProgramMetric {
  id         String   @id @default(cuid())
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  label      String
  value      Float
  unit       String?
  recordedAt DateTime @default(now())
}

model FundingSource {
  id           String   @id @default(cuid())
  name         String
  type         String
  amount       Float
  currency     String   @default("USD")
  status       String
  partnerId    String?
  partner      Partner? @relation(fields: [partnerId], references: [id])
  programId    String?
  program      Program? @relation(fields: [programId], references: [id])
  pledgeDate   DateTime?
  disbursedAt  DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  partnershipLinks PartnershipFunding[]
  disbursements    FundingDisbursement[]
}

model FundingDisbursement {
  id              String @id @default(cuid())
  fundingSourceId String
  fundingSource   FundingSource @relation(fields: [fundingSourceId], references: [id], onDelete: Cascade)
  amount          Float
  date            DateTime
  reference       String?
  notes           String?
}

model Hub {
  id              String   @id @default(cuid())
  name            String
  country         String
  region          String
  city            String?
  sector          String?
  websiteUrl      String?
  email           String?
  phone           String?
  foundedYear     Int?
  membershipTier  String   @default("STANDARD")
  status          String   @default("ACTIVE")
  africonnectId   String?  @unique
  engagementScore Int      @default(50)
  joinedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments   HubPayment[]
  programs   ProgramHub[]
  events     EventHub[]
  activities Activity[]
}

model HubPayment {
  id          String   @id @default(cuid())
  hubId       String
  hub         Hub      @relation(fields: [hubId], references: [id], onDelete: Cascade)
  amount      Float
  currency    String   @default("USD")
  status      String
  periodStart DateTime
  periodEnd   DateTime
  paidAt      DateTime?
  reference   String?
  createdAt   DateTime @default(now())
}

model ProgramHub {
  id        String  @id @default(cuid())
  programId String
  hubId     String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  hub       Hub     @relation(fields: [hubId], references: [id], onDelete: Cascade)
  role      String?

  @@unique([programId, hubId])
}

model Startup {
  id           String   @id @default(cuid())
  name         String
  country      String?
  sector       String?
  stage        String?
  founderName  String?
  founderEmail String?
  websiteUrl   String?
  raised       Float?
  jobsCreated  Int @default(0)
  hubId        String?
  createdAt    DateTime @default(now())

  programs ProgramStartup[]
}

model ProgramStartup {
  id        String  @id @default(cuid())
  programId String
  startupId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  startup   Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)
  cohort    String?

  @@unique([programId, startupId])
}

model Event {
  id          String   @id @default(cuid())
  name        String
  type        String
  status      String
  startDate   DateTime
  endDate     DateTime?
  location    String?
  city        String?
  country     String?
  capacity    Int?
  registered  Int @default(0)
  attended    Int @default(0)
  programId   String?
  program     Program? @relation(fields: [programId], references: [id])
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks      Task[]
  partners   EventPartner[]
  hubs       EventHub[]
  activities Activity[]
  messages   Message[]
}

model EventPartner {
  id            String  @id @default(cuid())
  eventId       String
  partnershipId String
  role          String?
  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  partnership   Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)

  @@unique([eventId, partnershipId])
}

model EventHub {
  id      String @id @default(cuid())
  eventId String
  hubId   String
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  hub     Hub   @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@unique([eventId, hubId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String
  priority    String   @default("MEDIUM")
  department  String?
  assigneeId  String?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id])
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Activity {
  id            String   @id @default(cuid())
  type          String
  title         String
  body          String?
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  partnershipId String?
  partnership   Partnership? @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  programId     String?
  program       Program?     @relation(fields: [programId], references: [id], onDelete: Cascade)
  eventId       String?
  event         Event?       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  hubId         String?
  hub           Hub?         @relation(fields: [hubId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@index([createdAt])
}

model Message {
  id            String  @id @default(cuid())
  authorId      String
  author        User    @relation(fields: [authorId], references: [id])
  body          String
  partnershipId String?
  partnership   Partnership? @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  programId     String?
  program       Program?     @relation(fields: [programId], references: [id], onDelete: Cascade)
  eventId       String?
  event         Event?       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model Campaign {
  id             String   @id @default(cuid())
  name           String
  channel        String
  audience       String
  audienceFilter String?
  subject        String?
  body           String
  status         String
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdById    String?
  createdBy      User?    @relation("CampaignCreator", fields: [createdById], references: [id])
  recipients     Int @default(0)
  opens          Int @default(0)
  clicks         Int @default(0)
  createdAt      DateTime @default(now())
}

model Booking {
  id        String   @id @default(cuid())
  type      String
  reference String?
  vendor    String?
  cost      Float?
  currency  String   @default("USD")
  status    String
  eventId   String?
  startDate DateTime?
  endDate   DateTime?
  notes     String?
  createdAt DateTime @default(now())
}

model Job {
  id           String   @id @default(cuid())
  title        String
  organization String
  location     String?
  type         String
  sector       String?
  link         String?
  postedAt     DateTime @default(now())
  expiresAt    DateTime?
  postedById   String?
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  entity     String
  entityId   String?
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model AfriconnectSyncLog {
  id          String   @id @default(cuid())
  endpoint    String
  direction   String
  status      String
  recordCount Int @default(0)
  errorMsg    String?
  createdAt   DateTime @default(now())
}
